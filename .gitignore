# ============================================================
#  MC Server Monitor - .gitignore
#  不需要上传到 GitHub 的文件
# ============================================================

# ---- Python 编译缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Python 打包 / 分发包 ----
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- PyInstaller 构建 ----
build/
dist/
*.spec.bak
*.spec.manifest
!mcmonitor.spec

# ---- 虚拟环境 ----
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# ---- 敏感数据（绝对禁止上传） ----
# 数据库文件（用户与服务器数据）
mcmonitor.db
*.db
*.db-journal
*.db-shm
*.db-wal
instance/

# 环境变量（真实配置）
.env
.env.local
.env.*.local

# 便携 Python 运行时
runtime/
site-packages/

# 日志文件
*.log
logs/

# 用户上传文件
uploads/

# ---- 临时 / 调试脚本（非正式测试脚本）----
_selftest_*.py
check_*.py
debug_*.py
fix_*.py
tmp_*.py

# ---- IDE / 编辑器配置 ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject

# Trae IDE 本地配置与草稿
.trae/

# ---- 操作系统垃圾文件 ----
# Windows
Thumbs.db
Thumbs.db.meta
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ---- 测试 / 覆盖率 ----
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
coverage.xml
*.cover
.hypothesis/

# ---- Node.js（如后续添加前端工具链）----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ---- 安全 / 密钥 ----
secrets.json
*.pem
*.key
*.crt
*.p12
*.pfx

# ---- 杂项 ----
*.bak
*.tmp
*.orig
*.rej
*.old

# 可执行文件
*.exe

# 压缩包
*.zip
*.tar.gz
*.tar
*.7z
*.rar
