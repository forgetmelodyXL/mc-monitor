# MC Server Monitor - 环境变量配置示例
# 复制此文件为 .env 并修改下方值

# 运行模式: development | production
MCMONITOR_ENV=development

# Session 密钥（留空则自动生成并保存到数据库，重启不丢失）
# 手动设置后将优先使用环境变量的值
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
MCMONITOR_SECRET_KEY=

# 监听地址与端口
MCMONITOR_HOST=0.0.0.0
MCMONITOR_PORT=5000

# 是否禁止自动打开浏览器 (1=禁止)
MCMONITOR_NOBROWSER=0

# 开发模式：开启热加载（代码修改自动重启），生产环境请勿开启
MCMONITOR_DEBUG=0

# 日志级别: DEBUG | INFO | WARNING | ERROR
MCMONITOR_LOG_LEVEL=INFO

# 日志目录（默认与数据库同目录）
# MCMONITOR_LOG_DIR=

# 数据库路径（默认 mcmonitor.db）
# MCMONITOR_DATABASE=

# 首次启动时，若设置了密码则自动创建 admin 超级管理员账号
# 密码长度至少 8 位
# 留空且数据库无用户时，自动生成随机密码并在控制台打印
MCMONITOR_BOOTSTRAP_PASSWORD=